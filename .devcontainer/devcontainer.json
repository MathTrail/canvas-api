{
    "name": "MathTrail Canvas API DevContainer",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "initializeCommand": "docker pull ghcr.io/mathtrail/platform-env:1",
    "features": {
        "ghcr.io/devcontainers/features/go:1": {
            "version": "1.26.0"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1.2.2": {
            "helm": "4.1.0",
            "version": "1.35.0",
            "minikube": "none"
        },
        "ghcr.io/eitsupi/devcontainer-features/just:0.1.1": {}
    },
    "mounts": [
        "source=${localEnv:USERPROFILE}/.kube,target=/home/vscode/.kube-host,type=bind,consistency=cached,readonly"
    ],
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway",
        "--add-host=k3d-mathtrail-registry.localhost:host-gateway"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "ms-azuretools.vscode-docker",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "redhat.vscode-yaml",
                "eamodio.gitlens",
                "sclu1034.justfile",
                "vscode-icons-team.vscode-icons",
                "anthropic.claude-code"
            ]
        }
    },
    "postStartCommand": "bash .devcontainer/post-start.sh",
    "forwardPorts": [8080]
}
